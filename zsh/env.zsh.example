# Example environment variables template
# Copy to ~/.zsh-local/env.zsh and fill in your values

# Company-specific SSH connections
# export COMPANY_JUMP_SSH="your-ssh-host"

# API Keys and Tokens
# export GITHUB_TOKEN='your-token-here'
# export API_KEY='your-key-here'

# Machine-specific paths
# export PATH="$PATH:/path/to/custom/bin"

# Tool-specific configuration
# export NODE_OPTIONS=--some-option
